# Telegram Bot — 기본 봇 (대화형 + 잡별 봇 미설정 시 fallback)
TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
TELEGRAM_CHAT_ID=123456789

# 잡별 별도 봇 (선택사항). 비워두면 기본 봇으로 전송.
# 채널 분리하고 싶으면 BotFather로 새 봇 만들고 토큰/채팅ID 입력.
# 빈 줄로 두면 기본 봇 사용.
TELEGRAM_BOT_TOKEN_INSIGHT=
TELEGRAM_CHAT_ID_INSIGHT=

# 글로벌 레이더(세계 시장·선도 기술·트렌드, 오전 8시·오후 8시).
# 비워두면 위 INSIGHT 채널로, 그것도 비면 기본 봇으로 전송.
TELEGRAM_BOT_TOKEN_RADAR=
TELEGRAM_CHAT_ID_RADAR=

TELEGRAM_BOT_TOKEN_CHART=
TELEGRAM_CHAT_ID_CHART=

TELEGRAM_BOT_TOKEN_DEEPDIVE=
TELEGRAM_CHAT_ID_DEEPDIVE=

# 미국/한국 시장 리포트도 분리하고 싶으면 추가 입력
TELEGRAM_BOT_TOKEN_US=
TELEGRAM_CHAT_ID_US=

TELEGRAM_BOT_TOKEN_KR=
TELEGRAM_CHAT_ID_KR=

# 매매 기록 봇 (사용자가 매수/매도 입력 시 구글 시트에 기록)
TELEGRAM_BOT_TOKEN_NOTE=
TELEGRAM_CHAT_ID_NOTE=

# 구글 시트 Apps Script 웹훅 URL (시트에 row append)
# 가이드: 시트 → 확장프로그램 → Apps Script → doPost 함수 작성 → 배포 → 웹앱 URL
NOTE_SHEET_URL=

# Claude Code CLI 모델 별칭 ("opus" | "sonnet" | "haiku")
# 또는 풀네임 (예: "claude-opus-4-7")
# Claude Code 로그인 세션을 사용하므로 ANTHROPIC_API_KEY 불필요
CLAUDE_MODEL=opus

# 옵션: OpenDART API 키 (https://opendart.fss.or.kr/uss/umt/EgovMberInsertView.do)
# 비워두면 네이버 비공식 API 사용. 키 입력 시 DART로 fallback/보강 가능.
OPEN_DART_API_KEY=

# 옵션: 평일에만 보낼지 (기본 true)
WEEKDAY_ONLY=true

# 옵션: launchd 설치 시 plist PATH에 넣을 `claude` CLI bin 디렉터리.
# 비워두면 install_launchd.sh가 `which claude`로 자동 탐지한다.
# 자동 탐지가 실패하거나 특정 node 설치를 강제하고 싶을 때만 지정.
# 예: NODE_BIN_DIR=/Users/you/.nvm/versions/node/v20.19.6/bin
NODE_BIN_DIR=
